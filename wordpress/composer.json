{
  "name": "sea/wp-ojs",
  "type": "project",
  "description": "WordPress + OJS integration (Bedrock-based)",
  "require": {
    "php": ">=8.2",
    "roots/bedrock-autoloader": "^1.0",
    "roots/bedrock-disallow-indexing": "^2.0",
    "roots/wordpress": "6.9.1",
    "roots/wp-config": "1.0.0",
    "roots/wp-password-bcrypt": "1.1.0",
    "vlucas/phpdotenv": "^5.6",
    "oscarotero/env": "^2.1",
    "wpackagist-plugin/woocommerce": "^9.8",
    "wpackagist-plugin/ultimate-member": "^2.11",
    "sea/woocommerce-subscriptions": "8.4.0",
    "sea/woocommerce-memberships": "1.27.5",
    "sea/um-notifications": "2.3.8",
    "sea/um-woocommerce": "2.4.4",
    "wpackagist-plugin/gantry5": "5.6.0"
  },
  "repositories": [
    {
      "type": "path",
      "url": "paid-plugins/woocommerce-subscriptions",
      "options": {
        "symlink": false
      }
    },
    {
      "type": "path",
      "url": "paid-plugins/woocommerce-memberships",
      "options": {
        "symlink": false
      }
    },
    {
      "type": "path",
      "url": "paid-plugins/um-notifications",
      "options": {
        "symlink": false
      }
    },
    {
      "type": "path",
      "url": "paid-plugins/um-woocommerce",
      "options": {
        "symlink": false
      }
    },
    {
      "type": "composer",
      "url": "https://wpackagist.org",
      "only": ["wpackagist-plugin/*", "wpackagist-theme/*"]
    }
  ],
  "extra": {
    "installer-paths": {
      "web/app/mu-plugins/{$name}/": ["type:wordpress-muplugin"],
      "web/app/plugins/{$name}/": ["type:wordpress-plugin"],
      "web/app/themes/{$name}/": ["type:wordpress-theme"]
    },
    "wordpress-install-dir": "web/wp"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "allow-plugins": {
      "composer/installers": true,
      "roots/wordpress-core-installer": true
    }
  }
}
