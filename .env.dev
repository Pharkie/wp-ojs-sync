# Dev environment for Existential Analysis.
#
# To create your .env:  scripts/generate-env.sh
# Passwords and secrets are left empty — generate-env.sh fills them in.
#
# QUOTING: This file is read by both Docker Compose and PHP's phpdotenv (Bedrock).
# phpdotenv requires quoting values that contain spaces. Use double quotes for
# plain text, single quotes for values containing double quotes (e.g. HTML with
# href="..."). Docker Compose strips outer quotes, so both parsers get the same value.

# === WordPress (Bedrock) ===
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=
DB_HOST=wp-db
WP_ENV=development
WP_HOME=http://localhost:8080
WP_SITEURL=${WP_HOME}/wp
WP_DEBUG_LOG=/var/www/html/web/app/uploads/debug.log
WP_ADMIN_PASSWORD=

# WP-OJS integration
WPOJS_API_KEY=
WPOJS_BASE_URL=http://ojs:80/index.php/journal

# WordPress database (Docker Compose)
WP_DB_ROOT_PASSWORD=
WP_DB_PASSWORD=

# === OJS ===
OJS_DB_HOST=ojs-db
OJS_DB_USER=ojs
OJS_DB_PASSWORD=
OJS_DB_NAME=ojs
OJS_DB_ROOT_PASSWORD=
OJS_BASE_URL=http://localhost:8081
OJS_TIMEZONE=Europe/London
OJS_ADMIN_USER=admin
OJS_ADMIN_PASSWORD=
OJS_ADMIN_EMAIL=admin@example.com

# Journal metadata
OJS_JOURNAL_PATH=journal
OJS_JOURNAL_NAME="Existential Analysis"
OJS_JOURNAL_ACRONYM=EA
OJS_JOURNAL_CONTACT_NAME="Richard Swann"
OJS_JOURNAL_CONTACT_EMAIL=journal@existentialanalysis.org.uk
OJS_JOURNAL_PUBLISHER="Society for Existential Analysis"
OJS_JOURNAL_PUBLISHER_URL=https://existentialanalysis.org.uk
OJS_JOURNAL_PRINT_ISSN=1752-5616
OJS_JOURNAL_ONLINE_ISSN=2044-0413
OJS_JOURNAL_COUNTRY=GB
OJS_JOURNAL_DESCRIPTION="Journal of the Society for Existential Analysis"
OJS_JOURNAL_ABOUT='<p>Existential Analysis aims to provide a forum for the expression of views and the exchange of ideas amongst those interested in existential-phenomenological analysis and its application to therapeutic practice and everyday life.</p><p>The journal is edited by Prof Simon du Plock and Dr Martin Adams, supported by an international Editorial Board and a Panel of Readers comprising established existential therapists, psychologists, and philosophers.</p><p>Published since 1990 by the <a href="https://existentialanalysis.org.uk">Society for Existential Analysis</a>.</p>'
OJS_JOURNAL_SUBSCRIPTION_INFO='<p>Members receive full access to all journal content as part of their membership. Non-members can purchase individual articles or issues.</p>'
OJS_SUB_TYPES="SEA Membership (all tiers):0"
OJS_PURCHASE_ARTICLE_FEE=3
OJS_PURCHASE_ISSUE_FEE=25

# WP-OJS plugin config (OJS side)
WPOJS_API_KEY_SECRET=
WPOJS_ALLOWED_IPS=172.0.0.0/8
WPOJS_WP_MEMBER_URL=http://localhost:8080
WPOJS_SUPPORT_EMAIL=
WPOJS_DEFAULT_LOGIN_HINT="SEA member? Log in with your membership email and password."
WPOJS_DEFAULT_PAYWALL_HINT="If you believe you should have access through your SEA membership, please contact <a href=\"mailto:{supportEmail}\">{supportEmail}</a>."
WPOJS_DEFAULT_FOOTER_MESSAGE="Your journal access is provided by your SEA membership. <a href=\"{wpUrl}\">Manage your membership</a>."
WPOJS_DEFAULT_PASSWORD_RESET_HINT='SEA members: <a href="{wpResetUrl}">change your password at the SEA website</a> — it will sync to the journal automatically. Passwords set here may be overwritten by your membership password.'

# Email (off in dev)
OJS_SMTP_ENABLED=Off
OJS_SMTP_HOST=
OJS_SMTP_PORT=587
OJS_SMTP_AUTH=tls
OJS_SMTP_USER=
OJS_SMTP_PASSWORD=
OJS_MAIL_FROM=noreply@localhost

# Caddy SSL (not used in dev)
CADDY_WP_DOMAIN=wp.example.org
CADDY_OJS_DOMAIN=ojs.example.org

# Auth salts (generate-env.sh fills these in)
AUTH_KEY=
SECURE_AUTH_KEY=
LOGGED_IN_KEY=
NONCE_KEY=
AUTH_SALT=
SECURE_AUTH_SALT=
LOGGED_IN_SALT=
NONCE_SALT=
