# Environment variables for Docker Compose + Bedrock.
#
# To create your .env:  scripts/generate-env.sh
# This generates random passwords and secrets automatically.
# You can also copy this file manually and fill in values yourself.
#
# QUOTING: This file is read by both Docker Compose and PHP's phpdotenv (Bedrock).
# phpdotenv requires quoting values that contain spaces. Use double quotes for
# plain text, single quotes for values containing double quotes (e.g. HTML with
# href="..."). Docker Compose strips outer quotes, so both parsers get the same value.

# === WordPress (Bedrock) ===
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=
DB_HOST=wp-db
WP_ENV=development
WP_HOME=http://localhost:8080
WP_SITEURL=${WP_HOME}/wp
WP_DEBUG_LOG=/var/www/html/web/app/uploads/debug.log
# REQUIRED — setup fails if empty. Use 'openssl rand -base64 24' for staging/prod.
WP_ADMIN_PASSWORD=

# WP-OJS integration
WPOJS_API_KEY=
WPOJS_BASE_URL=http://ojs:80/index.php/ea

# WordPress database (Docker Compose)
WP_DB_ROOT_PASSWORD=
WP_DB_PASSWORD=

# === OJS ===
OJS_DB_HOST=ojs-db
OJS_DB_USER=ojs
OJS_DB_PASSWORD=
OJS_DB_NAME=ojs
OJS_DB_ROOT_PASSWORD=
OJS_BASE_URL=http://localhost:8081
OJS_TIMEZONE=Europe/London
OJS_ADMIN_USER=admin
# REQUIRED — setup fails if empty. Use 'openssl rand -base64 24' for staging/prod.
OJS_ADMIN_PASSWORD=
OJS_ADMIN_EMAIL=admin@example.com
# Journal metadata (used by setup-ojs.sh)
# Required vars are marked [required] — setup will fail if missing.
# [required] URL path segment for the journal
OJS_JOURNAL_PATH=ea
# [required] Full journal title
OJS_JOURNAL_NAME="Your Journal Name"
# Short acronym (e.g. displayed in nav)
OJS_JOURNAL_ACRONYM=YJN
# [required] Primary contact name
OJS_JOURNAL_CONTACT_NAME="Journal Editor"
# [required] Primary contact email
OJS_JOURNAL_CONTACT_EMAIL=editor@example.com
# Publishing organisation name
OJS_JOURNAL_PUBLISHER="Your Organisation"
# Publisher website URL
OJS_JOURNAL_PUBLISHER_URL=https://example.com
# Print ISSN (if applicable)
OJS_JOURNAL_PRINT_ISSN=
# Online ISSN (if applicable)
OJS_JOURNAL_ONLINE_ISSN=
# Two-letter country code (e.g. GB, US)
OJS_JOURNAL_COUNTRY=
OJS_JOURNAL_DESCRIPTION="Short description of the journal"
OJS_JOURNAL_ABOUT='<p>About your journal. Supports HTML.</p>'
OJS_JOURNAL_SUBSCRIPTION_INFO='<p>Members receive full access to all journal content as part of their membership. Non-members can purchase individual articles or issues.</p>'
# Subscription types: pipe-separated "Name:Cost" entries (currency set via payments config).
# One type is usually sufficient — WC products handle tier/pricing differences.
OJS_SUB_TYPES="Membership (all tiers):0"
# Non-member purchase fees
OJS_PURCHASE_ARTICLE_FEE=3
OJS_PURCHASE_ISSUE_FEE=25
# WP-OJS plugin config (OJS side)
WPOJS_API_KEY_SECRET=
WPOJS_ALLOWED_IPS=172.0.0.0/8
WPOJS_WP_MEMBER_URL=http://localhost:8080
WPOJS_SUPPORT_EMAIL=
# UI messages shown to members (supports placeholders: {supportEmail}, {wpUrl})
WPOJS_DEFAULT_LOGIN_HINT="Member? Log in with your membership email and password."
WPOJS_DEFAULT_PAYWALL_HINT="If you believe you should have access through your membership, please contact <a href=\"mailto:{supportEmail}\">{supportEmail}</a>."
WPOJS_DEFAULT_FOOTER_MESSAGE="Your journal access is provided by your membership. <a href=\"{wpUrl}\">Manage your membership</a>."
WPOJS_DEFAULT_PASSWORD_RESET_HINT='Members: <a href="{wpResetUrl}">change your password on the membership website</a> — it will sync to the journal automatically. Passwords set here may be overwritten by your membership password.'

# DOI / Crossref (optional — only needed if registering DOIs)
OJS_DOI_PREFIX=
OJS_DOI_DEPOSITOR_NAME=
OJS_DOI_DEPOSITOR_EMAIL=
OJS_CROSSREF_USERNAME=
OJS_CROSSREF_PASSWORD=

# Email (off in dev)
OJS_SMTP_ENABLED=Off
OJS_SMTP_HOST=
OJS_SMTP_PORT=587
OJS_SMTP_AUTH=tls
OJS_SMTP_USER=
OJS_SMTP_PASSWORD=
OJS_MAIL_FROM=noreply@localhost

# Caddy SSL (only needed with docker-compose.caddy.yml overlay)
CADDY_WP_DOMAIN=wp.example.org
CADDY_OJS_DOMAIN=ojs.example.org

# Auth salts (generate with: wp dotenv salts generate)
AUTH_KEY=
SECURE_AUTH_KEY=
LOGGED_IN_KEY=
NONCE_KEY=
AUTH_SALT=
SECURE_AUTH_SALT=
LOGGED_IN_SALT=
NONCE_SALT=
