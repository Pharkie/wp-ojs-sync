; OJS configuration — generated from template by entrypoint.sh.
; Environment-specific values use ${VAR} substitution.
; Everything else is at OJS defaults.

;;;;;;;;;;;;;;;;;;
; General Settings
;;;;;;;;;;;;;;;;;;

[general]
app_key = ${OJS_APP_KEY}
installed = Off
base_url = "${OJS_BASE_URL}"
restful_urls = On
session_cookie_name = OJSSID
session_lifetime = 30
scheduled_tasks = On
time_zone = "${OJS_TIMEZONE}"
date_format_short = Y-m-d
date_format_long = F j, Y
datetime_format_short = Y-m-d h:i A
datetime_format_long = F j, Y - h:i A
time_format = h:i A
allowed_html = a[href|target|title],em,strong,cite,code,ul,ol,li[class],dl,dt,dd,b,i,u,img[src|alt],sup,sub,br,p

;;;;;;;;;;;;;;;;;;;;;;;
; Localization Settings
;;;;;;;;;;;;;;;;;;;;;;;

[i18n]
locale = en
connection_charset = utf8

;;;;;;;;;;;;;;;;;;;
; Database Settings
;;;;;;;;;;;;;;;;;;;

[database]
driver = mysqli
host = ${OJS_DB_HOST}
username = ${OJS_DB_USER}
password = ${OJS_DB_PASSWORD}
name = ${OJS_DB_NAME}

;;;;;;;;;;;;;;;;;;
; Cache Settings
;;;;;;;;;;;;;;;;;;

[cache]
cache = file
web_cache = Off
web_cache_hours = 1

;;;;;;;;;;;;;;;;;;;
; Security Settings
;;;;;;;;;;;;;;;;;;;

[security]
force_ssl = Off
force_login_ssl = Off
api_key_secret = ${WPOJS_API_KEY_SECRET}
password_reset_timeout = 7

;;;;;;;;;;;;;;
; File Settings
;;;;;;;;;;;;;;

[files]
files_dir = /var/www/files
public_files_dir = public

;;;;;;;;;;;;;;;;;;
; Email Settings
;;;;;;;;;;;;;;;;;;

[email]
default = sendmail
default_envelope_sender = ${OJS_MAIL_FROM}
smtp = ${OJS_SMTP_ENABLED}
smtp_server = ${OJS_SMTP_HOST}
smtp_port = ${OJS_SMTP_PORT}
smtp_auth = ${OJS_SMTP_AUTH}
smtp_username = ${OJS_SMTP_USER}
smtp_password = ${OJS_SMTP_PASSWORD}

;;;;;;;;;;;;;;;;;;;
; Search Settings
;;;;;;;;;;;;;;;;;;;

[search]
index = On
min_word_length = 3
results_per_keyword = 500
index[application/pdf] = "/usr/bin/pdftotext -enc UTF-8 -nopgbrk %s - | /usr/bin/tr '[:cntrl:]' ' '"

;;;;;;;;;;;;;;;;;;;
; OAI Settings
;;;;;;;;;;;;;;;;;;;

[oai]
oai = On
repository_id = ojs2.localhost

;;;;;;;;;;;;;;;;;;
; WP-OJS Integration
;;;;;;;;;;;;;;;;;;

[wpojs]
api_key_secret = ${WPOJS_API_KEY_SECRET}
allowed_ips = ${WPOJS_ALLOWED_IPS}
wp_member_url = ${WPOJS_WP_MEMBER_URL}
support_email = ${WPOJS_SUPPORT_EMAIL}
rate_limit_requests = 300
rate_limit_window = 60

; Instance-specific default UI messages (override generic plugin defaults).
; These pre-populate the Settings form. Admins can further edit via the UI.
; Available placeholders: {lostPasswordUrl}, {supportEmail}, {wpUrl}
default_login_hint = "${WPOJS_DEFAULT_LOGIN_HINT}"
default_paywall_hint = "${WPOJS_DEFAULT_PAYWALL_HINT}"
default_footer_message = "${WPOJS_DEFAULT_FOOTER_MESSAGE}"
