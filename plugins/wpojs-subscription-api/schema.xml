<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE schema SYSTEM "../../../lib/pkp/dtd/xmlSchema.dtd">

<schema version="0.2">
    <table name="wpojs_api_log">
        <field name="log_id" type="I8">
            <AUTOINCREMENT />
            <NOTNULL />
        </field>
        <field name="endpoint" type="C2" size="255">
            <NOTNULL />
        </field>
        <field name="method" type="C2" size="10">
            <NOTNULL />
        </field>
        <field name="source_ip" type="C2" size="45">
            <NOTNULL />
        </field>
        <field name="http_status" type="I2">
            <NOTNULL />
        </field>
        <field name="duration_ms" type="I4" />
        <field name="created_at" type="T">
            <NOTNULL />
        </field>
        <descr>API request log for WP-OJS sync plugin.</descr>
        <index name="wpojs_api_log_pkey">
            <col>log_id</col>
            <UNIQUE />
        </index>
        <index name="wpojs_api_log_created_at">
            <col>created_at</col>
        </index>
    </table>
</schema>
