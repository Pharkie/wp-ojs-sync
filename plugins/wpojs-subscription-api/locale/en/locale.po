msgid "plugins.generic.wpojsSubscriptionApi.displayName"
msgstr "WP–OJS Subscription API"

msgid "plugins.generic.wpojsSubscriptionApi.description"
msgstr "Exposes REST endpoints for WP↔OJS membership sync. Also adds login, paywall, and footer messages for members."

msgid "plugins.generic.wpojsSubscriptionApi.loginHint"
msgstr "Member visiting for the first time? <a href=\"{$lostPasswordUrl}\">Set your password</a> to access journal content."

msgid "plugins.generic.wpojsSubscriptionApi.paywallHint"
msgstr "If you should have access to this content, please contact <a href=\"mailto:{$supportEmail}\">{$supportEmail}</a>."

msgid "plugins.generic.wpojsSubscriptionApi.footerMessage"
msgstr "Your journal access is provided by your membership. <a href=\"{$wpUrl}\">Manage your membership</a>."

msgid "plugins.generic.wpojsSubscriptionApi.status"
msgstr "Status"

msgid "plugins.generic.wpojsSubscriptionApi.settings"
msgstr "Settings"

msgid "plugins.generic.wpojsSubscriptionApi.settings.description"
msgstr "Customise the messages shown to users on the login page, paywall, and site footer. Use the placeholders shown below each field."

msgid "plugins.generic.wpojsSubscriptionApi.settings.loginHint"
msgstr "Login page hint"

msgid "plugins.generic.wpojsSubscriptionApi.settings.paywallHint"
msgstr "Paywall hint (shown to logged-in users without a subscription)"

msgid "plugins.generic.wpojsSubscriptionApi.settings.footerMessage"
msgstr "Site footer message"

msgid "plugins.generic.wpojsSubscriptionApi.settings.save"
msgstr "Save"

msgid "plugins.generic.wpojsSubscriptionApi.settings.restoreDefaults"
msgstr "Restore defaults"

msgid "plugins.generic.wpojsSubscriptionApi.settings.saved"
msgstr "Saved."
