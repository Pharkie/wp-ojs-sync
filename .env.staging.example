# Staging environment — use strong generated passwords.
# Copy to .env.staging (or .env on the staging server) before deploying.

# === WordPress (Bedrock) ===
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=                    # openssl rand -base64 24
DB_HOST=wp-db
WP_ENV=staging
WP_HOME=https://staging-wp.example.com
WP_SITEURL=${WP_HOME}/wp
WP_DEBUG_LOG=/var/www/html/web/app/uploads/debug.log
WP_ADMIN_PASSWORD=              # openssl rand -base64 24

# WP-OJS integration
WPOJS_API_KEY=                # openssl rand -hex 32
WPOJS_BASE_URL=http://ojs:80/index.php/ea

# WordPress database (Docker Compose)
WP_DB_ROOT_PASSWORD=            # openssl rand -base64 24
WP_DB_PASSWORD=                 # openssl rand -base64 24

# === OJS ===
OJS_DB_HOST=ojs-db
OJS_DB_USER=ojs
OJS_DB_PASSWORD=                # openssl rand -base64 24
OJS_DB_NAME=ojs
OJS_DB_ROOT_PASSWORD=           # openssl rand -base64 24
OJS_BASE_URL=https://staging-ojs.example.com
OJS_TIMEZONE=Europe/London
OJS_ADMIN_USER=admin
OJS_ADMIN_PASSWORD=              # openssl rand -base64 24
OJS_ADMIN_EMAIL=admin@example.com

# Journal metadata (used by setup-ojs.sh)
# Required vars are marked [required] — setup will fail if missing.
OJS_JOURNAL_PATH=ea                                                                    # [required] URL path segment
OJS_JOURNAL_NAME="Existential Analysis: Journal of the Society for Existential Analysis"  # [required] Full title
OJS_JOURNAL_ACRONYM=EA                                                                 # Short acronym
OJS_JOURNAL_CONTACT_NAME="Journal Editor"                                              # [required] Primary contact
OJS_JOURNAL_CONTACT_EMAIL=editor@existentialanalysis.org.uk                            # [required] Contact email
OJS_JOURNAL_PUBLISHER="Society for Existential Analysis"                               # Publisher name
OJS_JOURNAL_PUBLISHER_URL=https://existentialanalysis.org.uk                           # Publisher URL
OJS_JOURNAL_PRINT_ISSN=                                                                # Print ISSN
OJS_JOURNAL_ONLINE_ISSN=                                                               # Online ISSN
OJS_JOURNAL_COUNTRY=GB                                                                 # Country code
OJS_JOURNAL_DESCRIPTION="Existential Analysis is the peer-reviewed journal of the Society for Existential Analysis, exploring existential-phenomenological perspectives on psychotherapy, counselling and human experience."
OJS_JOURNAL_ABOUT='<p>The SEA Journal is a biannual publication of the Society for Existential Analysis, focusing on existential psychotherapy, philosophy, and practice-based research. It is freely distributed to members and available for download, with a commitment to environmental responsibility by prioritizing digital access and printing only on request.</p><h3>Focus and Scope</h3><p>The journal publishes original theoretical articles, empirical studies, case reflections, and philosophical analysis, fostering dialogue and scholarship within existential psychotherapy and related disciplines.</p><p>Existential Analysis is edited by Prof Simon du Plock &amp; Dr Martin Adams. They can be contacted at <a href="mailto:journal@existentialanalysis.org.uk">journal@existentialanalysis.org.uk</a>. In addition to our international <a href="https://existentialanalysis.org.uk/publications/editorial-and-readers-board/">Editorial Board</a>, the journal also operates a <a href="https://existentialanalysis.org.uk/publications/editorial-and-readers-board/">Reader Panel</a>, all of whom are well-established Existential therapists, psychologists and philosophers with expertise in various areas of existential-phenomenological theory and practice. The Reader Panel contributes to the peer review process for publications and journal submissions.</p><p><a href="https://community.existentialanalysis.org.uk/product-category/hard-copy">Printed Hard copies</a> of Existential Analysis, from issue 37.1 onwards are available on Amazon using the print on demand service. Merely search for the issue and order a copy. A limited number of hard copies of previous issues are available to order. Once they have sold out, no further issues will be printed unless done so via Amazon using the print on demand service. Remaining printed hard copies cost £12 for SEA Members while they are logged into their account and £17 for non-members. Print on demand copies of new editions will cost £25.</p><p><a href="https://community.existentialanalysis.org.uk/product-category/journals">Buy a hard copy back issue of the Journal here</a> (subject to availability) or <a href="https://community.existentialanalysis.org.uk/sea-membership">join the society</a> to start receiving your e-journal copies as part of your membership.</p><h3>Editorial Responsibilities and Reader Policies</h3><ul><li>The editorial and review teams work voluntarily, ensuring academic integrity and community spirit.</li><li>Editors: Martin Adams and Simon du Plock oversee the selection, editing, and publication process.</li><li>Book Review Editor: Ondine Smulders commissions and edits all reviews including books and films.</li><li>Peer Review Editor: Richard Swann manages the peer review process.</li><li>Board and Reader Panel: Includes international academics and practitioners who contribute to editorial decisions and manuscript reviews.</li></ul>'
OJS_JOURNAL_SUBSCRIPTION_INFO='<p>Members receive full access to all journal content as part of their membership. Non-members can purchase individual articles or issues.</p>'
# Theme options (OJS default theme)
OJS_THEME_COLOUR=#b91515
OJS_THEME_TYPOGRAPHY=notoSans
OJS_THEME_SHOW_DESCRIPTION=1
# Subscription types: pipe-separated "Name:Cost" entries (currency set via payments config)
OJS_SUB_TYPES="Standard Membership:50|Student Membership:35"
# Non-member purchase fees
OJS_PURCHASE_ARTICLE_FEE=3
OJS_PURCHASE_ISSUE_FEE=25

# WP-OJS plugin config (OJS side)
WPOJS_API_KEY_SECRET=          # openssl rand -hex 32
WPOJS_ALLOWED_IPS=172.0.0.0/8
WPOJS_WP_MEMBER_URL=https://staging-wp.example.org
WPOJS_SUPPORT_EMAIL=
# UI messages shown to members (supports placeholders: {supportEmail}, {wpUrl})
WPOJS_DEFAULT_LOGIN_HINT="Member? Log in with your membership email and password."
WPOJS_DEFAULT_PAYWALL_HINT="If you believe you should have access through your membership, please contact <a href=\"mailto:{supportEmail}\">{supportEmail}</a>."
WPOJS_DEFAULT_FOOTER_MESSAGE="Your journal access is provided by your membership. <a href=\"{wpUrl}\">Manage your membership</a>."
WPOJS_DEFAULT_PASSWORD_RESET_HINT='Members: <a href="{wpResetUrl}">change your password on the membership website</a> — it will sync to the journal automatically. Passwords set here may be overwritten by your membership password.'

# Email (configure for staging)
OJS_SMTP_ENABLED=On
OJS_SMTP_HOST=smtp.example.com
OJS_SMTP_PORT=587
OJS_SMTP_AUTH=tls
OJS_SMTP_USER=
OJS_SMTP_PASSWORD=
OJS_MAIL_FROM=noreply@example.com

# Auth salts (generate with: wp dotenv salts generate)
AUTH_KEY=                       # openssl rand -base64 48
SECURE_AUTH_KEY=                # openssl rand -base64 48
LOGGED_IN_KEY=                  # openssl rand -base64 48
NONCE_KEY=                      # openssl rand -base64 48
AUTH_SALT=                      # openssl rand -base64 48
SECURE_AUTH_SALT=               # openssl rand -base64 48
LOGGED_IN_SALT=                 # openssl rand -base64 48
NONCE_SALT=                     # openssl rand -base64 48
